# Server
PORT=4001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://kiyota:kiyota@localhost:5432/kiyota

# Redis
REDIS_URL=redis://localhost:6379

# Zitadel instance (optional — only needed if you use Zitadel as an identity connector)
ZITADEL_DOMAIN=auth.local.kiyota.ai
ZITADEL_ORG_ID=
ZITADEL_PROJECT_ID=

# Service account used to call Zitadel management/user APIs.
# Prefer a Personal Access Token (PAT). If not provided, client credentials are used.
ZITADEL_SERVICE_PAT=
ZITADEL_SERVICE_CLIENT_ID=
ZITADEL_SERVICE_CLIENT_SECRET=

# Keystone OIDC app registered in Zitadel.
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=

# Optional external IdP IDs to skip the Zitadel login selector.
ZITADEL_GOOGLE_IDP_ID=
ZITADEL_GITHUB_IDP_ID=

# Generic identity connector configuration (optional).
# Set ISSUER, CLIENT_ID and CLIENT_SECRET for any provider you want to enable.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# OKTA_ISSUER=
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# KEYCLOAK_ISSUER=
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=

# Cookies
COOKIE_NAME=__Host-keystone-session
COOKIE_DOMAIN=.local.kiyota.ai
COOKIE_SECURE=false

# Tokens (seconds)
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# RSA PEM key pair. Leave empty in dev to auto-generate an ephemeral pair.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Origins allowed to call the Auth API with credentials.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4321

# Public URLs used in redirects and token issuer.
AUTH_API_PUBLIC_URL=http://localhost:4001
CLIENT_APP_URL=http://localhost:5173
RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Internal service-to-service
# Backwards-compatible alias: KIYOTA_INTERNAL_API_KEY
KEYSTONE_INTERNAL_API_KEY=change-me-to-a-random-32-char-secret

# Rate limiting
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=900
GLOBAL_RATE_LIMIT_MAX=100
GLOBAL_RATE_LIMIT_WINDOW=60

# Enhanced auth
HIBP_CHECK_ENABLED=false
# When true, new signups must verify their email (verification email sent on register)
EMAIL_VERIFICATION_REQUIRED=false
MAGIC_LINK_TTL_SECONDS=900
OAUTH_CODE_TTL_SECONDS=60
TOTP_ISSUER=Kiyota
KEYSTONE_TOTP_ENCRYPTION_KEY=

# Seeding
KEYSTONE_SEED_OWNER_EMAIL=
KEYSTONE_SEED_OWNER_PASSWORD=

# Encryption
# Master key for secrets stored in the database. Leave empty in dev to auto-generate a random key.
KEYSTONE_ENCRYPTION_KEY=

# Email / SMS providers (console, none)
EMAIL_PROVIDER=none
SMS_PROVIDER=none

# Background job queue: in-process, bullmq, or empty to auto-select bullmq when REDIS_URL is set.
KEYSTONE_QUEUE_PROVIDER=bullmq

# Secrets provider: database (default) or environment.
KEYSTONE_SECRETS_PROVIDER=database

# Audit exports
AUDIT_WEBHOOK_URL=
AUDIT_CONSOLE_EXPORT=false
